{
  "name": "marco-agent",
  "version": "0.2.0",
  "description": "A simple, extensible AI agent built on marco-harness.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "marco-agent": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/bin.ts"
  },
  "dependencies": {
    "marco-harness": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "agent",
    "anthropic",
    "claude",
    "marco",
    "marco-harness"
  ],
  "author": "Karan Kochar <karankochar13@gmail.com> (https://karankochar.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyrotank41/marco-agent.git"
  },
  "bugs": {
    "url": "https://github.com/pyrotank41/marco-agent/issues"
  },
  "homepage": "https://github.com/pyrotank41/marco-agent#readme"
}
